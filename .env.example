# Database — Neon Postgres
# Create a project at https://neon.tech and copy the pooled connection string.
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# Storage — Vercel Blob
# https://vercel.com/dashboard/stores → Create Blob store → copy RW token.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"

# Background jobs — Inngest
# https://app.inngest.com/env/production/manage/keys
INNGEST_EVENT_KEY="ingest_..."
INNGEST_SIGNING_KEY="signkey_..."
INNGEST_DEV="1" # "1" to use the local Inngest dev server, "0"/unset for prod

# Auth — Clerk
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# CV service — your Modal deployment
# Once you `modal deploy services/cv/app.py`, copy the public URL here.
CV_SERVICE_URL="https://your-workspace--cricket-cv.modal.run"
CV_SERVICE_TOKEN="generate-a-strong-random-string"
CV_WEBHOOK_HMAC_SECRET="generate-another-strong-random-string"

# Vision LLM — Gemini
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSy..."

# Public URL for the deployed app (used in webhooks / SSE absolute URLs).
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate limiting (optional, recommended in production)
# https://console.upstash.com — create a Redis database, copy REST URL + token.
# Uses token bucket + sliding window (see https://smudge.ai/blog/ratelimit-algorithms).
# If omitted, limits are disabled (fail-open).
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AXxxxx..."
